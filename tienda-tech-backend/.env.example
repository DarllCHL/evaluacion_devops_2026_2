# ============================================================
# tienda-tech-backend — Configuración de entorno
# Equivalente al application.properties del proyecto Spring
# ============================================================
# Uso: renombrar a .env en la carpeta tienda-tech-backend/
#      (nunca subir este archivo al repositorio)
# ============================================================

# --- Servidor ---
PORT=3001

# --- Base de datos MySQL ---
DB_HOST=db
DB_USER=alumno
DB_PASSWORD=alumno123
DB_NAME=tienda_tecnologica
DB_PORT=3306

# --- Configuración de conexión ---
DB_CONNECTION_LIMIT=10
DB_QUEUE_LIMIT=0

# --- Logs ---
LOG_LEVEL=info

# --- CORS ---
# Dominio permitido para peticiones del frontend.
# En local usar *, en producción especificar el origen exacto.
CORS_ORIGIN=*

# --- Entorno ---
NODE_ENV=development